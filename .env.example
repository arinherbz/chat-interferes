# Runtime
NODE_ENV=development
PORT=5050
HOST=127.0.0.1

# Database
# Local fallback example:
# DATABASE_URL=.data/dev.sqlite
# Neon / Render example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=.data/dev.sqlite

# Sessions / security
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=false
ALLOWED_ORIGINS=http://127.0.0.1:5050,http://localhost:5050

# Frontend
# Leave blank when the frontend is served by the same Express app.
VITE_API_URL=

# Logging
LOG_LEVEL=info
